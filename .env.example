# Backend LLM API keys
OPENROUTER_API_KEY=your-openrouter-key-here
# Production value is stored in Secret Manager; set this for local development
TAVILY_API_KEY=your-tavily-key-here

# Database (PostgreSQL)
# Production value is stored in Secret Manager; set this for local development
DATABASE_URL=postgresql://chatbot:password@localhost:5432/chatbot

# Server
PORT=3000
NODE_ENV=development
# Public HTTPS origin used by the backend's enableCors (no trailing slash).
# Set to your real domain in production; nginx terminates TLS in front of the backend.
CORS_ORIGIN=https://your-domain.example
# Max HTTP request body size (body-parser size string); must exceed base64 image-attachment
# payloads (~1.5 MB for a 1024px JPEG). Default 10mb when unset.
BODY_LIMIT=10mb

# Custom dino avatar storage — GCS bucket name (Phase 42-02).
# Create a public-read GCS bucket and grant the VM service account roles/storage.objectAdmin.
# When unset, avatar upload endpoint returns a clear error; all other custom-dino CRUD still works.
AVATAR_BUCKET=

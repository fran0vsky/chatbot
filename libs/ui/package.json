  "scripts": {
    "storybook": "storybook dev --config-dir .storybook --port 6006",
    "build-storybook": "storybook build --config-dir .storybook --output-dir ../../dist/storybook/ui"
  },
  "peerDependencies": {
    "@angular/common": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@angular/forms": ">=21.0.0",
    "@angular/platform-browser": ">=21.0.0",
    "ngx-markdown": ">=21.0.0"
  }
}
